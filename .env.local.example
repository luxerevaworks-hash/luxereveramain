# ====== ADMIN ======
# Comma separated list of admin emails.
# Must ALSO be added to firestore.rules and storage.rules (isAdmin() check),
# since security rules can't read env vars.
NEXT_PUBLIC_ADMIN_EMAILS=admin@luxereva.com
ADMIN_EMAILS=admin@luxereva.com

# ====== SITE ======
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ====== WHATSAPP (Meta Cloud API - from Meta Business Manager > WhatsApp > API Setup) ======
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
WHATSAPP_ACCESS_TOKEN=your_access_token
# Any string you choose — must match what you enter in the Meta webhook config
WHATSAPP_VERIFY_TOKEN=choose_a_verify_token
WHATSAPP_API_VERSION=v19.0
# Names of Meta-approved message templates (created in Business Manager)
WHATSAPP_TEMPLATE_ORDER_CONFIRMATION=order_confirmation
WHATSAPP_TEMPLATE_ORDER_SHIPPED=order_shipped

# ====== EMAIL (Gmail SMTP via nodemailer) ======
# Use a Google App Password, not your normal Gmail password (requires 2FA enabled
# on the account): https://myaccount.google.com/apppasswords
GMAIL_USER=your-store@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# ====== GOOGLE SEARCH CONSOLE ======
# The "content" value of the HTML verification meta tag Search Console gives you
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_verification_code
