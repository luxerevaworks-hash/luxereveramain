rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userProfilePath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function isAdmin() {
      return signedIn() &&
        exists(userProfilePath()) &&
        get(userProfilePath()).data.role == "admin";
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isSafeUserCreate(userId) {
      return isOwner(userId) &&
        (!("role" in request.resource.data) ||
          request.resource.data.role in ["customer", "user"]);
    }

    function isSafeUserUpdate(userId) {
      return isOwner(userId) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(["role"]);
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();

      match /reviews/{reviewId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /coupons/{couponId} {
      allow read, write: if isAdmin();
    }

    match /blogs/{blogId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Ephemeral live-visitor heartbeats — no PII, just path/productId/timestamp.
    // Anyone can write their own session doc; reads power the real-time
    // viewer count (product pages) and the admin live-visitors dashboard.
    match /presence/{sessionId} {
      allow read: if true;
      allow write: if request.resource.data.keys().hasOnly(["path", "productId", "lastSeen"]);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isSafeUserCreate(userId) || isAdmin();
      allow update: if isSafeUserUpdate(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if signedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow create: if false;
      allow delete: if isAdmin();
    }
  }
}
